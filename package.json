{
  "name": "keyframekit",
  "version": "1.2.3",
  "description": "Unlock fine-grained control over your CSS animations with JavaScript.",
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "test:dev": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "docs:bump": "(cd docs && npm run bump)"
  },
  "files": [
    "src",
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/benhatsor/KeyframeKit.git"
  },
  "keywords": [
    "css",
    "js",
    "javascript",
    "animation",
    "keyframe",
    "stylesheet",
    "tools",
    "performance",
    "typescript"
  ],
  "author": "Ben Hatsor",
  "license": "MIT",
  "types": "./dist/index.d.ts",
  "bugs": {
    "url": "https://github.com/benhatsor/KeyframeKit/issues"
  },
  "homepage": "https://keyframekit.berryscript.com",
  "type": "module",
  "devDependencies": {
    "@vitest/browser-playwright": "^4.1.4",
    "tsdown": "^0.21.7",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  },
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  }
}
